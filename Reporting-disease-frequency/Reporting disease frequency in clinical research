    "def add_margins(table: pd.DataFrame, row_total_name: str = \"Total\", column_total_name: str = \"Total\") -> pd.DataFrame:\n",
    "    table_with_totals = table.copy()\n",
    "    table_with_totals[column_total_name] = table_with_totals.sum(axis=1)\n",
    "    table_with_totals.loc[row_total_name] = table_with_totals.sum(axis=0)\n",
    "    return table_with_totals\n",
    "\n",
    "outcome_by_group_table = pd.crosstab(\n",
    "    analysis_data[\"group_label\"],\n",
    "    analysis_data[\"outcome_label\"],\n",
    "    dropna=False\n",
    ")\n",
    "\n",
    "tab = add_margins(outcome_by_group_table)\n",
    "display(tab)\n",
    "\n",
    "analysis_data[\"mechanical_ventilation_label\"] = analysis_data[\"mechanical_ventilation\"].map({0: \"No mechanical ventilation\", 1: \"Mechanical ventilation\"})\n",
    "mechanical_ventilation_by_group_table = pd.crosstab(analysis_data[\"group_label\"], analysis_data[\"mechanical_ventilation_label\"], dropna=False)\n",
    "display(add_margins(mechanical_ventilation_by_group_table))\n"
