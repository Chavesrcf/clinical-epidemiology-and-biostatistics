    "analysis_variables = [\n",
    "    \"patient\", \"group\", \"center\", \"follow_up_start\", \"follow_up_end\", \"follow_up_days\", \"follow_up_years\",\n",
    "    \"age\", \"platelet\", \"hemoglobin\", \"creatinine\", \"saps_3\", \"fluid_balance\", \"hypertension\", \"diabetes\",\n",
    "    \"heart_failure\", \"smoking\", \"chronic_kidney_disease\", \"cancer\", \"stroke\", \"vasopressor\",\n",
    "    \"mechanical_ventilation\", \"outcome\", \"event\"\n",
    "]\n",
    "available_analysis_variables = [variable for variable in analysis_variables if variable in data.columns]\n",
    "missing_analysis_variables = [variable for variable in analysis_variables if variable not in data.columns]\n",
    "if missing_analysis_variables:\n",
    "    print(\"Optional variables not found and skipped:\", missing_analysis_variables)\n",
    "\n",
    "analysis_data = data.loc[:, available_analysis_variables].copy()\n",
    "\n",
    "integer_variables = [\n",
    "    \"group\", \"center\", \"outcome\", \"event\", \"hypertension\", \"diabetes\", \"heart_failure\", \"smoking\",\n",
    "    \"chronic_kidney_disease\", \"cancer\", \"stroke\", \"vasopressor\", \"mechanical_ventilation\"\n",
    "]\n",
    "for variable in integer_variables:\n",
    "    if variable in analysis_data.columns:\n",
    "        analysis_data[variable] = pd.to_numeric(analysis_data[variable], errors=\"coerce\").astype(\"Int64\")\n",
    "\n",
    "for variable in [\"follow_up_start\", \"follow_up_end\"]:\n",
    "    if variable in analysis_data.columns:\n",
    "        analysis_data[variable] = pd.to_datetime(analysis_data[variable], errors=\"coerce\")\n",
    "\n",
    "analysis_data[\"calculated_follow_up_days\"] = (analysis_data[\"follow_up_end\"] - analysis_data[\"follow_up_start\"]).dt.days\n",
    "analysis_data[\"person_time_days\"] = pd.to_numeric(analysis_data[\"follow_up_days\"], errors=\"coerce\")\n",
    "analysis_data[\"person_time_years\"] = pd.to_numeric(analysis_data[\"follow_up_years\"], errors=\"coerce\")\n",
    "analysis_data[\"at_risk_discharge\"] = analysis_data[\"outcome\"].notna().astype(int)\n",
    "analysis_data[\"at_risk_followup\"] = (\n",
    "    analysis_data[\"event\"].notna() & analysis_data[\"person_time_years\"].notna() & (analysis_data[\"person_time_years\"] > 0)\n",
    ").astype(int)\n",
    "\n",
    "comorbidity_variables = [\"hypertension\", \"diabetes\", \"heart_failure\", \"smoking\", \"chronic_kidney_disease\", \"cancer\", \"stroke\"]\n",
    "available_comorbidity_variables = [variable for variable in comorbidity_variables if variable in analysis_data.columns]\n",
    "analysis_data[\"comorbidity_any\"] = analysis_data[available_comorbidity_variables].eq(1).any(axis=1).astype(int)\n",
    "\n",
    "analysis_data[\"group_label\"] = analysis_data[\"group\"].map({0: \"Control\", 1: \"Intervention\"})\n",
    "analysis_data[\"outcome_label\"] = analysis_data[\"outcome\"].map({0: \"Alive\", 1: \"Dead\"})\n",
    "analysis_data[\"event_label\"] = analysis_data[\"event\"].map({0: \"Censored\", 1: \"Event occurred\"})\n",
    "\n",
    "display(analysis_data.head())\n"
   ]
